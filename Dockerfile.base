FROM node:20-alpine
WORKDIR /app

# Install Claude Code globally
RUN npm install -g @anthropic-ai/claude-code

# Install project dependencies with fixed versions (no ^ prefix)
RUN npm install \
  express@4.18.2 \
  better-sqlite3@9.4.3 \
  bcryptjs@2.4.3 \
  jsonwebtoken@9.0.2 \
  cors@2.8.5 \
  helmet@7.1.0 \
  compression@1.7.4

RUN npm install path-to-regexp@6.3.0
ENV NODE_PATH=/app/node_modules
EXPOSE 3000
